                        "required": true,
                        "options": [
                            { "id": "technology", "label": "기술인 경우", "value": "technology" },
                            { "id": "service", "label": "서비스인 경우", "value": "service" },
                            { "id": "technologyAndService", "label": "기술과 서비스가 융합된 경우", "value": "technologyAndService" }
