{
    "temporary-1": {
        "formId": "temporary-1",
        "formName": "임시허가 신청서",
        "version": "1.0",
        "sections": [
            {
                "key": "receipt",
                "label": "접수정보",
                "fields": [
                    { "key": "receiptNumber", "label": "접수번호", "formType": "text", "dataType": "string", "required": false },
                    { "key": "receiptDate", "label": "접수일시", "formType": "date", "dataType": "date", "required": false }
                ]
            },
            {
                "key": "applicant",
                "label": "신청인",
                "fields": [
                    { "key": "companyName", "label": "회사명(성명)", "formType": "text", "dataType": "string", "required": true },
                    { "key": "businessRegistrationNumber", "label": "사업자(법인)등록번호", "formType": "text", "dataType": "string", "required": true },
                    { "key": "address", "label": "주소", "formType": "text", "dataType": "string", "required": true },
                    { "key": "representativeName", "label": "대표자명", "formType": "text", "dataType": "string", "required": true },
                    { "key": "phoneNumber", "label": "전화번호", "formType": "text", "dataType": "string", "required": true },
                    { "key": "email", "label": "전자우편", "formType": "text", "dataType": "string", "required": true }
                ]
            },
            {
                "key": "technologyService",
                "label": "신규 기술·서비스",
                "fields": [
                    { "key": "name", "label": "명칭", "formType": "text", "dataType": "string", "required": true },
                    {
                        "key": "type",
                        "label": "유형",
                        "formType": "radio",
                        "dataType": "string",
                        "required": true,
                        "options": [
                            { "id": "technology", "label": "기술인 경우", "value": "technology" },
                            { "id": "service", "label": "서비스인 경우", "value": "service" },
                            { "id": "technologyAndService", "label": "기술과 서비스가 융합된 경우", "value": "technologyAndService" }
                        ]
                    },
                    { "key": "mainContent", "label": "주요내용", "formType": "textarea", "dataType": "text", "required": true }
                ]
            },
            {
                "key": "temporaryPermitReason",
                "label": "임시허가 신청 사유",
                "fields": [
                    {
                        "key": "temporaryPermitReason",
                        "label": "해당 난에 표시(√)",
                        "formType": "checkbox",
                        "dataType": "array",
                        "required": true,
                        "options": [
                            {
                                "id": "noApplicableStandards",
                                "label": "허가등의 근거가 되는 법령에 해당 신규 정보통신융합등 기술·서비스에 맞는 기준·규격·요건 등이 없는 경우(법 제37조제1항제1호)",
                                "value": "noApplicableStandards"
                            },
                            {
                                "id": "unclearOrUnreasonableStandards",
                                "label": "허가등의 근거가 되는 법령에 따른 기준·규격·요건 등을 적용하는 것이 불명확하거나 불합리한 경우(법 제37조제1항제2호)",
                                "value": "unclearOrUnreasonableStandards"
                            }
                        ]
                    }
                ]
            },
            {
                "key": "application",
                "label": "신청",
                "fields": [
                    { "key": "applicationDate", "label": "신청일자", "formType": "date", "dataType": "date", "required": true },
                    { "key": "applicantSignature", "label": "신청인 성명(서명 또는 인)", "formType": "text", "dataType": "string", "required": true }
                ]
            }
        ]
    },
