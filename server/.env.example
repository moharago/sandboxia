# .env
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
CORS_ORIGINS=https://
CORS_ORIGIN_REGEX=https://ai-camp-4nd-llm-agent-service-project-4th-law.*\.vercel\.app
# LLM 설정
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
# Upstage 설정 
UPSTAGE_API_KEY=up_...
# 법령 API 설정
LAW_API_BASE_URL=
LAW_API_OC=
# Google Drive 설정 (RAG 데이터 다운로드용, 폴더 경로)
GOOGLE_DRIVE_URL=https://drive.google.com/drive/folders/
R1_DATA_ID=
R2_DATA_ID=
DRAFT_TEMPLATE_FASTCHECK_ID=
DRAFT_TEMPLATE_TEMPORARY_ID=
DRAFT_TEMPLATE_DEMONSTRATION_ID=
# Vector DB
CHROMA_MODE=persistent  # persistent (로컬 파일) | http (서버 연결) | ephemeral (인메모리)
CHROMA_HOST=localhost   # http 모드 전용
CHROMA_PORT=8000        # http 모드 전용
CHROMA_PERSIST_DIR=./data/chroma  # persistent 모드 전용
# Supabase 설정
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# LangSmith 설정 (Token/Cost 추적용, 평가 스크립트 --trace 옵션 사용 시 활성화)
LANGCHAIN_API_KEY=lsv2_pt_...